<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cm.enspy.gcu.chantier.controller.ZoneController"
            style="-fx-background-color: #1a1a2e; -fx-padding: 20;">
    <top>
        <VBox spacing="5" style="-fx-padding: 0 0 15 0;">
            <Label text="🗺️ Gestion des Zones" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
            <Label text="Configuration des zones et niveaux de sécurité" style="-fx-font-size: 12px; -fx-text-fill: #8a8aaa;"/>
        </VBox>
    </top>
    <center>
        <HBox spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="10">
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="+ Nouvelle Zone" onAction="#modeNouvel"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="zoneTable" VBox.vgrow="ALWAYS" prefHeight="480"
                           style="-fx-background-color: #0d1b3e;">
                    <columns>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="200"/>
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="280"/>
                        <TableColumn fx:id="colNiveau" text="Niveau Séc." prefWidth="100"/>
                        <TableColumn fx:id="colCapacite" text="Capacité max" prefWidth="110"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="80"/>
                    </columns>
                    <placeholder><Label text="Aucune zone configurée" style="-fx-text-fill: #8a8aaa;"/></placeholder>
                </TableView>
            </VBox>
            <VBox prefWidth="300" spacing="10"
                  style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20;">
                <Label fx:id="formTitle" text="Nouvelle Zone"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                <Separator/>
                <Label text="Nom *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="nomField" promptText="Nom de la zone"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>
                <Label text="Description" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextArea fx:id="descriptionArea" promptText="Description de la zone" prefHeight="80" wrapText="true"
                          style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                <Label text="Niveau de sécurité (1-4)" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <Spinner fx:id="niveauSpinner" maxWidth="Infinity"
                         style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                <Label text="Capacité maximale" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <Spinner fx:id="capaciteSpinner" maxWidth="Infinity"
                         style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                <Separator/>
                <Button text="💾 Sauvegarder" onAction="#handleSauvegarder" maxWidth="Infinity"
                        style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>
                <Button text="🔄 Activer/Désactiver" onAction="#handleDesactiver" maxWidth="Infinity"
                        style="-fx-background-color: #16213e; -fx-text-fill: #c0c0d8; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
