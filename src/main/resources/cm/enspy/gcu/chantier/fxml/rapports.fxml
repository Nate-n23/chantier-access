<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cm.enspy.gcu.chantier.controller.RapportController"
            style="-fx-background-color: #1a1a2e; -fx-padding: 20;">
    <top>
        <VBox spacing="5" style="-fx-padding: 0 0 15 0;">
            <Label text="📊 Génération des Rapports" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
            <Label text="Export PDF et CSV vers ~/ChantierAcces/rapports/" style="-fx-font-size: 12px; -fx-text-fill: #8a8aaa;"/>
        </VBox>
    </top>
    <center>
        <HBox spacing="15">
            <!-- Configuration rapport -->
            <VBox prefWidth="280" spacing="12"
                  style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20;">
                <Label text="Type de rapport" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                <VBox spacing="8">
                    <RadioButton fx:id="radioJournalier" text="📅 Journalier"
                                 style="-fx-text-fill: #c0c0d8;"/>
                    <RadioButton fx:id="radioHebdomadaire" text="📆 Hebdomadaire"
                                 style="-fx-text-fill: #c0c0d8;"/>
                    <RadioButton fx:id="radioMensuel" text="🗓 Mensuel"
                                 style="-fx-text-fill: #c0c0d8;"/>
                    <RadioButton fx:id="radioIncidents" text="⚠️ Incidents / Refus"
                                 style="-fx-text-fill: #c0c0d8;"/>
                </VBox>

                <Separator/>
                <Label text="Période" style="-fx-text-fill: #e94560; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label text="Date de début" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <DatePicker fx:id="dateDebutPicker" maxWidth="Infinity"
                            style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                <Label text="Date de fin" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <DatePicker fx:id="dateFinPicker" maxWidth="Infinity"
                            style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Separator/>
                <Label text="Filtres" style="-fx-text-fill: #e94560; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label text="Zone" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <ComboBox fx:id="zoneFiltreCombo" maxWidth="Infinity"
                          style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                <Label text="Statut accès" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <ComboBox fx:id="statutFiltreCombo" maxWidth="Infinity"
                          style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Separator/>
                <Button text="🔍 Générer aperçu" onAction="#handleGenererAperçu" maxWidth="Infinity"
                        style="-fx-background-color: #2196f3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>
                <HBox spacing="8">
                    <Button text="📄 Export PDF" onAction="#handleExporterPDF" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8; -fx-cursor: hand;"/>
                    <Button text="📊 Export CSV" onAction="#handleExporterCSV" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8; -fx-cursor: hand;"/>
                </HBox>
                <Label fx:id="statusLabel" text="" style="-fx-text-fill: #8a8aaa; -fx-font-size: 11px;" wrapText="true"/>
            </VBox>

            <!-- Aperçu rapport -->
            <VBox HBox.hgrow="ALWAYS" spacing="10"
                  style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 15;">
                <Label text="📋 Aperçu du rapport" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                <TextArea fx:id="aperçuArea" VBox.vgrow="ALWAYS" wrapText="false"
                          promptText="Cliquez sur 'Générer aperçu' pour afficher le rapport ici..."
                          style="-fx-background-color: #0d1b3e; -fx-text-fill: #c0c0d8; -fx-font-family: monospace; -fx-font-size: 12px; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
