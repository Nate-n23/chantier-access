<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cm.enspy.gcu.chantier.controller.DashboardController"
            style="-fx-background-color: #1a1a2e;">

    <!-- SIDEBAR GAUCHE -->
    <left>
        <VBox styleClass="sidebar" style="-fx-background-color: #16213e; -fx-min-width: 230px; -fx-max-width: 230px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 8, 0, 2, 0);">
            <!-- Header sidebar -->
            <VBox style="-fx-background-color: #0f3460; -fx-padding: 20 15 20 15; -fx-spacing: 4;">
                <Label text="🏗️ Chantier Accès" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                <Label text="v1.0 — ENSPY" style="-fx-font-size: 11px; -fx-text-fill: #8a8aaa;"/>
            </VBox>
            <Separator style="-fx-opacity: 0.3;"/>

            <!-- Navigation -->
            <VBox spacing="2" style="-fx-padding: 10 0 10 0;">
                <Button fx:id="navIntervenants" text="👷 Intervenants" onAction="#navIntervenants" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
                <Button fx:id="navBadges" text="🏷️ Badges" onAction="#navBadges" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
                <Button fx:id="navAcces" text="🔑 Contrôle Accès" onAction="#navAcces" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
                <Button fx:id="navZones" text="🗺️ Zones" onAction="#navZones" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
                <Button fx:id="navEpi" text="🦺 EPI" onAction="#navEpi" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
                <Separator style="-fx-opacity: 0.3; -fx-padding: 5 15;"/>
                <Button fx:id="navRapports" text="📊 Rapports" onAction="#navRapports" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
                <Button fx:id="navAdmin" text="⚙️ Administration" onAction="#navAdmin" maxWidth="Infinity" styleClass="nav-button"
                        style="-fx-background-color: transparent; -fx-text-fill: #c0c0d8; -fx-font-size: 13px; -fx-alignment: center-left; -fx-padding: 12 15; -fx-cursor: hand; -fx-border-width: 0;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-opacity: 0.3;"/>

            <!-- Infos utilisateur + déconnexion -->
            <VBox style="-fx-padding: 10 15; -fx-spacing: 8;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="👤" style="-fx-font-size: 16px;"/>
                    <VBox spacing="1">
                        <Label fx:id="userLabel" text="Utilisateur" style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Label fx:id="roleLabel" text="Rôle" style="-fx-text-fill: #8a8aaa; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
                <Button text="⇠ Déconnexion" onAction="#handleLogout" maxWidth="Infinity"
                        style="-fx-background-color: rgba(233,69,96,0.15); -fx-text-fill: #e94560; -fx-border-color: #e94560; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 12; -fx-font-size: 12px;"/>
            </VBox>
        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <VBox style="-fx-background-color: #1a1a2e;">
            <!-- Header top -->
            <HBox style="-fx-background-color: #0f3460; -fx-padding: 12 20; -fx-alignment: center-left; -fx-spacing: 15; -fx-pref-height: 56px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 6, 0, 0, 2);">
                <Label fx:id="headerTitle" text="Tableau de Bord" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Tableau de Bord" style="-fx-text-fill: #e94560; -fx-font-size: 13px;"/>
            </HBox>

            <!-- Zone de contenu scrollable -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1a2e; -fx-background: #1a1a2e;">
                <VBox style="-fx-padding: 20; -fx-spacing: 20; -fx-background-color: #1a1a2e;">

                    <!-- KPI Cards -->
                    <HBox spacing="15">
                        <VBox styleClass="kpi-card" style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 6, 0, 0, 2); -fx-min-width: 180;" HBox.hgrow="ALWAYS">
                            <Label text="👷 Présents Aujourd'hui" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                            <Label fx:id="kpiPresents" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #4caf50;"/>
                        </VBox>
                        <VBox styleClass="kpi-card" style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 6, 0, 0, 2); -fx-min-width: 180;" HBox.hgrow="ALWAYS">
                            <Label text="🔔 Alertes Non Lues" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                            <Label fx:id="kpiAlertes" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ff9800;"/>
                        </VBox>
                        <VBox styleClass="kpi-card" style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 6, 0, 0, 2); -fx-min-width: 180;" HBox.hgrow="ALWAYS">
                            <Label text="🏷️ Badges Expirant (7j)" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                            <Label fx:id="kpiBadgesExpirés" text="..." style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                        </VBox>
                        <VBox styleClass="kpi-card" style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 6, 0, 0, 2); -fx-min-width: 180;" HBox.hgrow="ALWAYS">
                            <Label text="⚠️ Incidents Aujourd'hui" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                            <Label fx:id="kpiIncidents" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                        </VBox>
                    </HBox>

                    <!-- Graphique + Alertes -->
                    <HBox spacing="15">
                        <!-- Graphique fréquentation -->
                        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 15; -fx-spacing: 10;">
                            <Label text="📈 Fréquentation — 7 derniers jours" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                            <BarChart fx:id="frequentationChart" animated="false" style="-fx-background-color: transparent;" prefHeight="250">
                                <xAxis><CategoryAxis label="Zone" style="-fx-tick-label-fill: #8a8aaa;"/></xAxis>
                                <yAxis><NumberAxis label="Passages" style="-fx-tick-label-fill: #8a8aaa;"/></yAxis>
                            </BarChart>
                        </VBox>

                        <!-- Alertes non lues -->
                        <VBox prefWidth="350" style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 15; -fx-spacing: 10;">
                            <Label text="🔔 Alertes Non Lues" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                            <Label text="Double-clic pour marquer comme lue" style="-fx-font-size: 11px; -fx-text-fill: #8a8aaa;"/>
                            <TableView fx:id="alertesTable" VBox.vgrow="ALWAYS" prefHeight="230"
                                       style="-fx-background-color: #0d1b3e;">
                                <columns>
                                    <TableColumn fx:id="colAlerteDate" text="Date" prefWidth="130"/>
                                    <TableColumn fx:id="colAlerteGravite" text="Gravité" prefWidth="100"/>
                                    <TableColumn fx:id="colAlerteMessage" text="Message" prefWidth="200"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </HBox>

                    <!-- Derniers accès -->
                    <VBox style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 15; -fx-spacing: 10;">
                        <Label text="🔑 10 Derniers Accès" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                        <TableView fx:id="derniersAccesTable" prefHeight="250"
                                   style="-fx-background-color: #0d1b3e;">
                            <columns>
                                <TableColumn fx:id="colAccesDate" text="Date/Heure" prefWidth="160"/>
                                <TableColumn fx:id="colAccesIntervenant" text="Intervenant" prefWidth="200"/>
                                <TableColumn fx:id="colAccesZone" text="Zone" prefWidth="180"/>
                                <TableColumn fx:id="colAccesType" text="Type" prefWidth="80"/>
                                <TableColumn fx:id="colAccesStatut" text="Statut" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- STACK PANE pour les modules -->
    <fx:define>
        <StackPane fx:id="contentArea"/>
    </fx:define>
</BorderPane>
