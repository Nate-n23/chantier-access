<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cm.enspy.gcu.chantier.controller.EpiController"
            style="-fx-background-color: #1a1a2e; -fx-padding: 20;">
    <top>
        <VBox spacing="5" style="-fx-padding: 0 0 15 0;">
            <Label text="🦺 Gestion des EPI" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
            <Label text="Équipements de Protection Individuelle — Attribution et suivi d'état" style="-fx-font-size: 12px; -fx-text-fill: #8a8aaa;"/>
        </VBox>
    </top>
    <center>
        <HBox spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="epiCountLabel" text="Total: 0"
                           style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                </HBox>
                <TableView fx:id="epiTable" VBox.vgrow="ALWAYS" prefHeight="480"
                           style="-fx-background-color: #0d1b3e;">
                    <columns>
                        <TableColumn fx:id="colType" text="Type EPI" prefWidth="130"/>
                        <TableColumn fx:id="colIntervenant" text="Intervenant" prefWidth="200"/>
                        <TableColumn fx:id="colTaille" text="Taille" prefWidth="80"/>
                        <TableColumn fx:id="colEtat" text="État" prefWidth="110"/>
                        <TableColumn fx:id="colDate" text="Date attribution" prefWidth="160"/>
                    </columns>
                    <placeholder><Label text="Aucun EPI enregistré" style="-fx-text-fill: #8a8aaa;"/></placeholder>
                </TableView>
                <!-- Boutons changement d'état -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Changer état de l'EPI sélectionné:" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                    <Button text="✅ BON" onAction="#handleMarquerBon"
                            style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
                    <Button text="⚠️ USAGÉ" onAction="#handleMarquerUsage"
                            style="-fx-background-color: #ff9800; -fx-text-fill: #000; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
                    <Button text="🔴 À REMPLACER" onAction="#handleMarquerARemplacer"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Formulaire attribution -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        prefWidth="300" minWidth="300" styleClass="edge-to-edge"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox spacing="10"
                      style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20;">
                    <Label text="Attribuer un EPI" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                    <Separator/>
                    <Label text="Intervenant *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="intervenantCombo" maxWidth="Infinity"
                              style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Label text="Type d'EPI *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="typeEpiCombo" maxWidth="Infinity"
                              style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Label text="Taille / Référence" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                    <TextField fx:id="tailleField" promptText="Ex: L, XL, 42, Standard"
                               style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>
                    <Separator/>
                    <Button text="✅ Attribuer EPI" onAction="#handleAttribuer" maxWidth="Infinity"
                            style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>

                    <!-- Légende états -->
                    <Separator style="-fx-padding: 10 0 0 0;"/>
                    <Label text="Légende états:" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="●" style="-fx-text-fill: #4caf50; -fx-font-size: 16px;"/>
                        <Label text="BON — EPI en bon état" style="-fx-text-fill: #8a8aaa; -fx-font-size: 11px;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="●" style="-fx-text-fill: #ff9800; -fx-font-size: 16px;"/>
                        <Label text="USAGÉ — EPI correctement utilisé" style="-fx-text-fill: #8a8aaa; -fx-font-size: 11px;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="●" style="-fx-text-fill: #e94560; -fx-font-size: 16px;"/>
                        <Label text="À REMPLACER — EPI hors service" style="-fx-text-fill: #8a8aaa; -fx-font-size: 11px;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </HBox>
    </center>
</BorderPane>
