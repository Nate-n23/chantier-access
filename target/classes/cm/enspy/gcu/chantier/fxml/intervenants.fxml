<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cm.enspy.gcu.chantier.controller.IntervenantController"
            style="-fx-background-color: #1a1a2e; -fx-padding: 20;">

    <top>
        <VBox spacing="5" BorderPane.alignment="CENTER_LEFT" style="-fx-padding: 0 0 15 0;">
            <Label text="👷 Gestion des Intervenants" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
            <Label text="CRUD complet — recherche en temps réel" style="-fx-font-size: 12px; -fx-text-fill: #8a8aaa;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="15">
            <!-- LISTE + RECHERCHE -->
            <VBox HBox.hgrow="ALWAYS" spacing="10">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="🔍 Rechercher par nom, matricule, entreprise..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #0f3460; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>
                    <Button text="+ Nouveau" onAction="#modeNouvel" styleClass="btn-primary"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="intervenantTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #0d1b3e; -fx-pref-height: 500;">
                    <columns>
                        <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="110"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="130"/>
                        <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="130"/>
                        <TableColumn fx:id="colEntreprise" text="Entreprise" prefWidth="150"/>
                        <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="110"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="90"/>
                    </columns>
                    <placeholder><Label text="Aucun intervenant trouvé" style="-fx-text-fill: #8a8aaa;"/></placeholder>
                </TableView>
            </VBox>

            <!-- FORMULAIRE -->
            <VBox prefWidth="320" spacing="10"
                  style="-fx-background-color: #0f3460; -fx-background-radius: 10; -fx-padding: 20;">
                <Label fx:id="formTitle" text="Nouvel Intervenant"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                <Separator/>

                <Label text="Matricule *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="matriculeField" promptText="Ex: MAT-2024-001"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Nom *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="nomField" promptText="Nom de famille"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Prénom *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="prenomField" promptText="Prénom"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Date de naissance" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <DatePicker fx:id="dateNaissancePicker" maxWidth="Infinity"
                            style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Label text="Téléphone" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="telephoneField" promptText="+237 6XX XX XX XX"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Email" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField" promptText="email@exemple.com"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Entreprise *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <TextField fx:id="entrepriseField" promptText="Nom de l'entreprise"
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: #e0e0e0; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Catégorie *" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <ComboBox fx:id="categorieCombo" maxWidth="Infinity"
                          style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Label text="Niveau d'habilitation (1-4)" style="-fx-text-fill: #8a8aaa; -fx-font-size: 12px;"/>
                <Spinner fx:id="niveauHabSpinner" maxWidth="Infinity"
                         style="-fx-background-color: #1a1a2e; -fx-border-color: #334; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Separator/>

                <!-- Actions -->
                <Button fx:id="btnSauvegarder" text="💾 Sauvegarder" onAction="#handleSauvegarder"
                        maxWidth="Infinity" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>
                <HBox spacing="8">
                    <Button fx:id="btnSuspendre" text="⏸ Suspendre" onAction="#handleSuspendre"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" disable="true"
                            style="-fx-background-color: #ff9800; -fx-text-fill: #000; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8; -fx-cursor: hand;"/>
                    <Button fx:id="btnArchiver" text="🗄 Archiver" onAction="#handleArchiver"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity" disable="true"
                            style="-fx-background-color: #555577; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
